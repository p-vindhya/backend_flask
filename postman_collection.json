{
  "info": {
    "name": "Data Pipeline API Collection",
    "description": "Postman collection for testing Flask and FastAPI endpoints in the data pipeline project.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Flask API",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "health"]
            }
          }
        },
        {
          "name": "Get Customers (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/customers?page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Customer",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:5000/api/customers/CUST001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "customers", "CUST001"]
            }
          }
        }
      ]
    },
    {
      "name": "FastAPI",
      "item": [
        {
          "name": "Ingest Data",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": ""
            },
            "url": {
              "raw": "http://localhost:8000/api/ingest",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "ingest"]
            }
          }
        },
        {
          "name": "Get Customers (Paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/customers?page=1&limit=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "customers"],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Customer",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8000/api/customers/CUST001",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8000",
              "path": ["api", "customers", "CUST001"]
            }
          }
        }
      ]
    }
  ]
}